<% if badge_style? %>
  <% if total > 0 %>
    <a
      href="<%= user_feedbacks_path(search: { user_id: user.id }) %>"
      class="user-records-list"
      data-negative="<%= negative %>"
      data-neutral="<%= neutral %>"
      data-positive="<%= positive %>"
      data-total="<%= positive - negative %>"
    >
      <%= svg_badge(deleted, "deleted") if deleted > 0 %>
      <%= svg_badge(negative, "negative") if negative > 0 %>
      <%= svg_badge(neutral, "neutral") if neutral > 0 %>
      <%= svg_badge(positive, "positive") if positive > 0 %>
    </a>
  <% end %>

  <% if show_add_feedback? %>
    <a
      href="<%= new_user_feedback_path(user_feedback: { user_id: user.id, category: "neutral" }) %>"
      class="user-records-list"
      title="New Feedback"
    >
      <%= svg_badge("+", "neutral") %>
    </a>
  <% end %>
<% elsif inline_style? %>
  <% if active > 0 %>
    <%= link_to(
      safe_join([
        (tag.span(positive, class: "user-feedback-positive") if positive > 0),
        (tag.span(neutral, class: "user-feedback-neutral") if neutral > 0),
        (tag.span(negative, class: "user-feedback-negative") if negative > 0),
      ].compact),
      user_feedbacks_path(search: { user_id: user.id }),
      class: "user-feedback-list"
    ) %>
  <% end %>
<% end %>
