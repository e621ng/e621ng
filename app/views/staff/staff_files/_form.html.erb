<div id="form-content">
  <%= error_messages_for("staff_file") %>

  <%= custom_form_for(@staff_file) do |f| %>
    <%= f.input :file, as: :file %>
    <%= f.input :title, hint: "Optional. Defaults to the uploaded filename." %>
    <%= f.input :description %>
    <%= f.button :submit, "Upload" %>
  <% end %>
</div>
