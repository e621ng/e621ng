<div id="c-admin-vote-trends">
  <h1>Vote Trends</h1>
  <p>
    This page shows the voting trends for a specific user. You can filter the results by various parameters.
    If a tag's score is <code>inf</code>, that means that the tag's count is out-of-date.
  </p>
  <%= render "staff/vote_trends/partials/show/options" %>
  <br>
  <table>
    <thead>
      <tr>
        <th class="vt-score">Score</th>
        <th class="vt-tag">Tag Name</th>
      </tr>
    </thead>
    <tbody>
      <%= render partial: "staff/vote_trends/partials/show/ranked_tag", collection: @vote_trends, as: :trend_tag %>
    </tbody>
  </table>
</div>
