<div id="c-users"><div id="a-upload-limit">

  <% is_current_user = @user.id == CurrentUser.id %>
  <% karma = @user.upload_karma %>
  <% threshold = Danbooru.config.upload_karma_free_threshold %>
  <% pending_limit = Danbooru.config.upload_karma_pending_limit %>
  <% pending_count = @user.pending_post_count %>

  <!-- Header -->
  <%= render "/users/partials/show/card", presenter: @presenter, user: @user %>

  <!-- Wiki -->
  <div class="profile-container dtext-container">
    <h2>Upload Karma</h2>
    <%= format_text(@page.body, allow_color: true) %>
  </div>

  <!-- Status -->
  <div class="profile-container">
    <% if @user.no_uploading %>
      <p><%= is_current_user ? "You" : link_to_user(@user) %> cannot upload posts.</p>

      <% if is_current_user %>
        <p class="profile-notice">
          Your ability to upload posts had been manually disabled by a staff member.<br />
          If you believe that this was done in error, <%= link_to "contact an admin", show_or_new_wiki_pages_path(title: "e621:staff") %> to have this situation resolved.
        </p>
      <% end %>
    <% elsif @user.upload_karma_free? %>
      <p><%= is_current_user ? "You" : link_to_user(@user) %> can upload posts <strong>without manual approval</strong>.</p>
      <p>Upload karma: <strong><%= karma %></strong> (threshold: <%= threshold %>)</p>
    <% else %>
      <p>
        <%= is_current_user ? "You" : link_to_user(@user) %> can have at most
        <strong><%= pending_limit %></strong> posts pending approval at a time
        (<strong><%= pending_count %></strong> currently pending).
      </p>
      <p>
        Upload karma: <strong><%= karma %></strong> / <%= threshold %> needed to unlock approval-free uploads.
      </p>
    <% end %>
  </div>

  <% if is_current_user %>
    <!-- Throttle -->
    <div class="profile-container">
      <p>
        You are limited to <%= Danbooru.config.hourly_upload_limit %> uploads per hour.
      </p>
      <ul>
        <li>Remaining hourly uploads: <%= CurrentUser.hourly_upload_limit %></li>
        <% unless CurrentUser.upload_karma_free? || CurrentUser.is_privileged? %>
          <li>Remaining hourly tag edits: <%= CurrentUser.post_edit_limit %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

</div></div>

<%= render "secondary_links" %>

<% content_for(:page_title) do %>
  Upload Karma
<% end %>
