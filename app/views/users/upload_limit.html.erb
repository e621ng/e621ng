<div id="c-users"><div id="a-upload-limit">

  <% pieces = @user.upload_slots_pieces %>
  <% karma_threshold_enabled = !Danbooru.config.upload_karma_free_threshold.nil? %>
  <% karma_threshold = karma_threshold_enabled ? @user.required_karma_for_level(Danbooru.config.upload_karma_free_threshold) : nil %>
  <% is_current_user = @user.id == CurrentUser.id %>

  <!-- Header -->
  <%= render "/users/partials/show/card", presenter: @presenter, user: @user %>

  <!-- Wiki -->
  <div class="profile-container dtext-container">
    <h2>Upload Limit</h2>
    <%= format_text(@page.body, allow_color: true) %>
  </div>

  <!-- Formula -->
  <div class="profile-container">
    <% if @user.no_uploading %>
      <p><%= is_current_user ? "You" : link_to_user(@user) %> cannot upload posts.</p>

      <% if is_current_user %>
        <p class="profile-notice">
          Your ability to upload posts had been manually disabled by a staff member.<br />
          If you believe that this was done in error, <%= link_to "contact an admin", show_or_new_wiki_pages_path(title: "e621:staff") %> to have this situation resolved.
        </p>
      <% end %>
    <% else %>
      <p>
        <%= is_current_user ? "You have" : link_to_user(@user) + " has".html_safe %>
        <strong><%= @user.upload_karma %></strong> upload karma.<br />
        Each approved upload grants <strong>+1</strong> karma, while each rejected upload deducts <strong>-3</strong> karma.
        <% if karma_threshold_enabled %>
          <br />
          At <strong><%= karma_threshold %></strong> karma, uploads bypass the queue entirely.
        <% end %>
      </p>

      <% if @user.upload_karma_free? %>
        <p><%= is_current_user ? "Your" : "This user's" %> uploads bypass the review queue and are posted directly as approved.</p>
      <% else %>
        <p>
          <%= is_current_user ? "You" : link_to_user(@user) %> currently
          <%= is_current_user ? "have" : "has" %> <strong><%= @user.upload_slots %></strong>
          upload slot<%= @user.upload_slots == 1 ? "" : "s" %> in the review queue,
          based on the following formula:
        </p>

        <span class="upload-limit-formula">
          <span class="upl-element"><abbr class="upl-base" title="Base Upload Slots"><%= pieces[:base] %></abbr></span>

          <span class="upl-group">
            <span class="upl-math"><%= svg_icon(:plus) %></span>
            <span class="upl-element">
              <abbr class="upl-approved" title="Approved Posts and Replacements"><%= pieces[:approved] %></abbr> / 10
            </span>
          </span>

          <span class="upl-group">
            <span class="upl-math"><%= svg_icon(:minus) %></span>
            <span class="upl-element">
              <abbr class="upl-pending" title="Pending or Flagged Posts, Pending Replacements"><%= pieces[:pending] %></abbr>
            </span>
          </span>

          <span class="upl-group">
            <span class="upl-math"><%= svg_icon(:minus) %></span>
            <span class="upl-element">
              <abbr class="upl-deleted" title="Deleted or Replaced Posts, Rejected Replacements&#013;<%= pieces[:deleted_ignore] %> of your Replaced Posts do not affect your upload slots">
                <%= pieces[:deleted] %></abbr> / 4
            </span>
          </span>

          <span class="upl-group">
            <span class="upl-math"><%= svg_icon(:equals) %></span>
            <span class="upl-element">
              <abbr class="upl-total" title="Remaining Upload Slots"><%= @user.upload_slots %></abbr>
            </span>
          </span>
        </span>

        <div class="upload-limit-explanation">
          <abbr title="Base Upload Slots" class="ul-num upl-base"><%= pieces[:base] %></abbr>
          <div class="ul-exp">
            <h5>Base Slots</h5>
            <span>Default number of concurrent queued uploads allowed.</span>
          </div>

          <abbr title="Approved Posts and Replacements" class="ul-num upl-approved"><%= pieces[:approved] %></abbr>
          <div class="ul-exp">
            <h5>Approved Posts and Replacements</h5>
            <span>Uploads that had been manually approved.</span>
          </div>

          <abbr title="Pending or Flagged Posts, Pending Replacements" class="ul-num upl-pending"><%= pieces[:pending] %></abbr>
          <div class="ul-exp">
            <h5>Pending / Flagged</h5>
            <span>Posts that are currently awaiting review.</span>
          </div>

          <abbr title="Deleted or Replaced Posts, Rejected Replacements" class="ul-num upl-deleted"><%= pieces[:deleted] %></abbr>
          <div class="ul-exp">
            <h5>Deleted / Replaced / Rejected</h5>
            <span>Uploads that had been rejected, one way or another.</span>
          </div>

          <abbr title="Remaining Upload Slots" class="ul-num upl-total"><%= @user.upload_slots %></abbr>
          <div class="ul-exp">
            <h5>Upload Slots</h5>
            <span>
              Remaining number of posts that can be queued for review.<br />
              This number is capped at <strong><%= Danbooru.config.upload_slots_base %></strong> slots.
            </span>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>

  <% if is_current_user %>
    <!-- Throttle -->
    <div class="profile-container">
      <p>
        You are limited to 30 uploads per hour.
      </p>
      <ul>
        <li>Remaining hourly uploads: <%= CurrentUser.hourly_upload_limit %></li>
        <% unless CurrentUser.upload_karma_free? || CurrentUser.is_privileged? %>
          <li>Remaining hourly tag edits: <%= CurrentUser.post_edit_limit %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

</div></div>

<%= render "secondary_links" %>

<% content_for(:page_title) do %>
  Upload Limit
<% end %>
