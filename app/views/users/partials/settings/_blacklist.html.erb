<% tab_name = "blacklist" %>

<!-- Accessibility -->
<setting-group name="blacklisting">Blacklist</setting-group>

<setting-entry tab="<%= tab_name %>" group="blacklisting" class="bigtext" search="posts blacklisted filtered tags blocked">
  <setting-title>Blacklisted Tags</setting-title>
  <setting-body>
    <%= form.textarea :blacklisted_tags, label: false, autocomplete: "tag-query", rows: 8 %>
  </setting-body>
  <setting-hint>
    Put any tag combinations you never want to see here. Each combination should go on a separate line. <a href='/help/blacklist'>View help.</a>
  </setting-hint>
</setting-entry>

<setting-entry tab="<%= tab_name %>" group="blacklisting" class="inline" search="posts blacklisted filter users comments blips forum">
  <setting-title>Blacklist Users</setting-title>
  <setting-body>
    <%= form.input_field :blacklist_users, as: :boolean, class: "st-toggle" %>
    <%= form.label :blacklist_users, "!", class: "st-toggle", role: "switch" %>
  </setting-body>
  <setting-hint>
    Hide comments, blips and forum posts from users that have been blacklisted, in addition to posts.
  </setting-hint>
</setting-entry>
