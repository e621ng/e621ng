<div id="c-appeals">
  <div id="a-show">
    <div class="section">
      <h3><%= @appeal.type_title %> Appeal</h3>

      <table>
        <%# Reporter %>
        <tr>
          <td><span class='title'>Requested by</span></td>
          <td>
            <%= link_to_user @appeal.creator %>
            (<%= link_to "Pending Appeals", appeals_path(search: { creator_id: @appeal.creator.id, status: "pending" }) %>)
          </td>
        </tr>

        <%# IP Address %>
        <% if CurrentUser.is_admin? %>
          <tr>
            <td><span class='title'>IP</span></td>
            <td><%= link_to_ip(@appeal.creator_ip_addr) %></td>
          </tr>
        <% end %>

        <%# Accused %>
        <% if @appeal.accused.present? %>
          <tr>
            <td><span class="title">Accused</span></td>
            <td>
              <%= link_to_user @appeal.accused %>
              <% if (pending_accused_count = Appeal.active.for_accused(@appeal.accused.id).count) >= 2 %>
                (<%= link_to "#{pending_accused_count} Pending", appeals_path(search: { accused_id: @appeal.accused.id, status: "pending" }) %>)
              <% end %>
            </td>
          </tr>
        <% end %>

        <%# Timestamps %>
        <tr>
          <td><span class="title">Created</span></td>
          <td style="cursor:help;"><%= time_ago_in_words_tagged(@appeal.created_at) %></td>
        </tr>
        <tr>
          <td><span class="title">Updated</span></td>
          <td style="cursor:help;"><%= time_ago_in_words_tagged(@appeal.updated_at) %></td>
        </tr>

        <%# Claimed / Handled %>
        <% if @appeal.response.present? %>
          <tr>
            <td><span class='title'>Handled by</span></td>
            <% if @appeal.handler.present? %>
              <td><%= link_to_user @appeal.handler %></td>
            <% else %>
              <td>Unknown</td>
            <% end %>
          </tr>
        <% elsif CurrentUser.is_staff? %>
          <tr>
            <td><span class="title">Claimed by</span></td>
            <td id="claimed_by">
              <%= link_to_user @appeal.claimant if @appeal.claimant.present? %>
              <% if @appeal.can_claim?(CurrentUser.user) %>
                <% if @appeal.claimant.nil? %>
                  <%= link_to 'Claim', claim_appeal_path(@appeal), method: :post %>
                <% elsif @appeal.claimant.id == CurrentUser.id %>
                  | <%= link_to "Unclaim", unclaim_appeal_path(@appeal), method: :post %>
                <% end %>
              <% end %>
            </td>
          </tr>
        <% end %>

        <tr>
          <td><span class='title'>Status</span></td>
          <td class="<%= @appeal.status %>-appeal"><%= pretty_ticket_status(@appeal) %></td>
        </tr>

        <% if CurrentUser.is_staff? %>
          <% open_duplicates = @appeal.open_duplicates.to_a %>
          <% if open_duplicates.any? %>
            <tr>
              <td><span class="title">Open Duplicates</span></td>
              <td>
                <ul>
                  <% open_duplicates.each do |dup| %>
                    <li><%= link_to("Appeal #{dup.id} - #{dup.subject}", appeal_path(dup.id)) %></li>
                  <% end %>
                </ul>
              </td>
            </tr>
          <% end %>
        <% end %>

        <%= render partial: "appeals/types/#{@appeal.qtype}" %>

        <tr>
          <td><span class='title'>Reason</span></td>
          <td>
            <% if @appeal.qtype == "post" && @appeal.post_report_reason.present? %>
              <span class="appeal-reason"><%= @appeal.post_report_reason.reason %></span>
            <% end %>
            <div class="dtext-container appeal-block">
              <%= format_text(@appeal.reason) %>
            </div>
          </td>
        </tr>

        <% if @appeal.response.present? %>
          <tr>
            <td><span class='title'>Response</span></td>
            <td>
              <div class="dtext-container appeal-block unmargined">
                <%= format_text(@appeal.response) %>
              </div>
            </td>
          </tr>
        <% end %>
      </table>
    </div>

    <% if CurrentUser.is_staff? && @appeal.can_handle? %>
      <div class="section">
        <%= custom_form_for(@appeal) do |f| %>
          <%= f.input :status, collection: [["Investigated", "approved"], ["Under Investigation", "partial"]], selected: @appeal.status || "approved" %>
          <% if @appeal.warnable? %>
            <%= f.input :record_type, label: "Mark the #{@appeal.content.model_name.singular.humanize(capitalize: false)} as having received", collection: @appeal.content.class.warning_types.to_h { |k, v| ["A #{k}", v] }, include_blank: "Nothing" %>
          <% end %>
          <% unless @appeal.pending? %>
            <%= f.input :send_update_dmail, label: "Send update DMail", as: :boolean, hint: "A DMail is always sent if the status is changed" %>
          <% end %>
          <table>
            <tr>
              <td><%= f.input :response, as: :dtext, limit: Danbooru.config.dmail_max_size, allow_color: false %></td>
            </tr>
          </table>
          <%= tag.input name: "force_claim", type: "hidden", value: params[:force_claim] %>
          <%= f.button :submit, "Submit" %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>

<% content_for(:title) do %>
  <%= @appeal.type_title %>
<% end %>

<% render partial: 'secondary_links' %>

<% content_for(:page_title) do %>
  <%= @appeal.type_title %> Appeal
<% end %>
