<ul>
  <li><%= link_to "Sets with this post", post_sets_path(post_id: @post.id), rel: "nofollow" %></li>
  <% if IqdbProxy.enabled? && @post.has_preview? %>
    <li><%= link_to "Visually similar on E6", iqdb_queries_path(search: { post_id: @post.id }), rel: "nofollow noreferrer", data: { hotkey: "iqdb" } %></li>
  <% end %>
  <% if @post.visible? %>
    <li class="list-break"></li>
    <li><a rel="nofollow noreferrer" target="_blank" href="https://lens.google.com/uploadbyurl?url=<%= @post.reverse_image_url %>&client=e621" data-hotkey="ris-google">Google</a></li>
    <li><a rel="nofollow noreferrer" target="_blank" href="https://saucenao.com/search.php?url=<%= @post.reverse_image_url %>" data-hotkey="ris-saucenao">SauceNAO</a></li>
    <li><a rel="nofollow noreferrer" target="_blank" href="https://derpibooru.org/search/reverse?url=<%= @post.reverse_image_url %>" data-hotkey="ris-derpi">Derpibooru</a></li>
    <li><a rel="nofollow noreferrer" target="_blank" href="https://yandex.com/images/search?url=<%= @post.reverse_image_url %>&rpt=imageview" data-hotkey="ris-yandex">Yandex</a></li>
    <li><a rel="nofollow noreferrer" target="_blank" href="https://fuzzysearch.net/#url=<%= @post.reverse_image_url %>" data-hotkey="ris-fzsearch">FuzzySearch</a></li>
    <li><a rel="nofollow noreferrer" target="_blank" href="https://fluffle.xyz/#url=<%= @post.reverse_image_url %>" data-hotkey="ris-fluffle">Fluffle</a></li>
  <% end %>
  <li class="list-break"></li>
  <li><a rel="nofollow noreferrer" target="_blank" href="https://inkbunny.net/search_process.php?text=<%= @post.md5 %>&md5=yes" data-hotkey="ris-inkbunny">Inkbunny</a></li>
</ul>
