<% @dmail = @ticket.content %>
<tr>
  <td><span class='title'>Reported Message</span></td>
  <td>
    <%= link_to "Message", dmail_path(@dmail) %>
    sent from <%= link_to_user @dmail.from %> to
    <%= link_to_user @dmail.to %>
  </td>
</tr>
<%= render partial: "tickets/partials/content_age", locals: { ticket: @ticket, content: "DMail" } %>
