<div id="c-search-trends">
  <div id="a-show">
    <h1>
      Search Trends for <%= @tag %>
    </h1>

    <% if @trends.blank? %>
      <p>No data for this tag yet.</p>
    <% else %>
      <table class="striped">
        <thead>
          <tr>
            <th>Date</th>
            <th>Hour</th>
            <th>Searches</th>
          </tr>
        </thead>
        <tbody>
          <% @trends.each do |row| %>
            <tr>
              <td><%= row.day.to_s %></td>
              <td><%= row.hour %></td>
              <td><%= row.count %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% end %>

    <%= link_to "Back to trending tags", search_trends_path(day: @trends.first&.day || Time.now.utc.to_date) %>
  </div>
</div>

<%= render "secondary_links" %>

<% content_for(:page_title) do %>
  Trending Tags - <%= @tag %>
<% end %>

