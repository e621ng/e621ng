<div id="c-search-trends">
  <div id="a-index">
    <h1>Search Trends</h1>

    <div class="search-trend-container search-trend-list">
      <h3>
        <%= svg_icon(:trending_up) %>
        Trending
      </h3>
      <%= rising_tags %>
    </div>

    <div class="search-trend-nav">
      <a href="<%= url_for(day: @day - 1) %>"><%= svg_icon(:chevron_left) %> Previous</a>
      <strong><%= @day.to_s %></strong>
      <a href="<%= url_for(day: @day + 1) %>">Next <%= svg_icon(:chevron_right) %></a>
    </div>

    <% if @trending.blank? %>
      <p>No trending data for this day yet.</p>
    <% else %>
      <table class="striped">
        <thead>
          <tr>
            <th>#</th>
            <th>Tag</th>
            <th>Searches</th>
          </tr>
        </thead>
        <tbody>
          <% @trending.each_with_index do |row, idx| %>
            <tr>
              <td><%= @count_offset + idx + 1 %></td>
              <td><%= link_to row.tag, posts_path(tags: row.tag) %></td>
              <td><%= row.count %></td>
            </tr>
          <% end %>
        </tbody>
      </table>

      <%= render PaginatorComponent.new(records: @trending) %>
    <% end %>
  </div>
</div>

<%= render "secondary_links" %>

<% content_for(:page_title) do %>
  Trending tags
<% end %>
