<h1>User Cleanup: <%= link_to @user.name, user_path(@user) %></h1>

<div class="cleanup-actions">
  <% if @has_avatar %>
    <section class="box-section">
      <h2>Clear Avatar</h2>
      <p>Remove the user's avatar, including the cropped version if present.</p>
      <%= button_to "Clear Avatar",
            clear_avatar_moderator_user_cleanup_path(@user),
            class: "st-button",
            data: { confirm: "Clear this user's avatar?" } %>
    </section>
  <% end %>

  <% if @has_profile_info %>
    <section class="box-section">
      <h2>Archive & Clear Profile Text</h2>
      <p>Copy <code>profile_about</code> and <code>profile_artinfo</code> into a staff note, then clear both fields.</p>
      <%= button_to "Archive & Clear",
            clear_profile_moderator_user_cleanup_path(@user),
            class: "st-button",
            data: { confirm: "Archive and clear this user's profile text?" } %>
    </section>
  <% end %>

  <% if @has_visible_comments %>
    <section class="box-section">
      <h2>Hide All Comments</h2>
      <p>
        Hide every visible comment by this user.<br />
        <span class="hint">Performed in a background job, may take some time.</span>
      </p>
      <%= button_to "Hide Comments",
            hide_comments_moderator_user_cleanup_path(@user),
            class: "st-button",
            data: { confirm: "Schedule hiding all comments by #{@user.name}?" } %>
    </section>
  <% end %>

  <% if @has_visible_forum_posts %>
    <section class="box-section">
      <h2>Hide All Forum Posts & Topics</h2>
      <p>
        Hide all visible forum posts and topics by this user.<br />
        <span class="hint">Performed in a background job, may take some time.</span>
      </p>
      <%= button_to "Hide Forum Posts",
            hide_forum_posts_moderator_user_cleanup_path(@user),
            class: "st-button",
            data: { confirm: "Schedule hiding all forum activity by #{@user.name}?" } %>
    </section>
  <% end %>

  <% if @has_visible_blips %>
    <section class="box-section">
      <h2>Hide All Blips</h2>
      <p>
        Hide all visible blips by this user.<br />
        <span class="hint">Performed in a background job, may take some time.</span>
      </p>
      <%= button_to "Hide Blips",
            hide_blips_moderator_user_cleanup_path(@user),
            class: "st-button",
            data: { confirm: "Schedule hiding all blips by #{@user.name}?" } %>
    </section>
  <% end %>

  <% if @has_revertable_changes %>
    <section class="box-section">
      <h2>Tag Changes</h2>
      <p>
        Undo all changes to post tags made by this user, except for uploads.
      </p>
      <%= link_to "Revert All", new_user_revert_path(user_id: @user.id), class: "st-button" %>
    </section>
  <% end %>
</div>

<%= render "users/secondary_links" %>

<% content_for(:page_title) do %>
  User Cleanup: <%= @user.name %>
<% end %>
