<div id="c-staff-wikis">
  <div id="a-show">
    <aside id="sidebar"></aside>

    <section id="content">
      <h1 id="staff-wiki-title"><%= @staff_wiki.pretty_title %></h1>

      <div id="staff-wiki-body" class="dtext-container">
        <p>This page does not exist yet. <%= link_to "Click here to create it", new_staff_wiki_path(staff_wiki: { title: params[:title] }) %>.</p>
      </div>
    </section>
  </div>
</div>

<% content_for(:page_title) do %>
  Staff Wiki - <%= @staff_wiki.pretty_title %>
<% end %>

<%= render "secondary_links" %>
