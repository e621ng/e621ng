<% content_for(:secondary_links) do %>
  <% if @latest.present? %>
    <%= subnav_link_to "Latest", @latest %>
  <% end %>
  <% if CurrentUser.is_admin? %>
    <%= subnav_link_to "User Vote Trends", admin_vote_trends_path(user: params.dig(:search, :user_name) || params.dig(:search, :user_id)) %>
  <% end %>
<% end %>
